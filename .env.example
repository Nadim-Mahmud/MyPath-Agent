ENV=development

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Routing server API key (must match routing-server/src/main/resources/application.properties api.key)
ROUTING_API_KEY=your-routing-api-key-here

# Frontend build args
VITE_API_KEY=your-routing-api-key-here
VITE_AI_CORE_URL=http://localhost:8000
